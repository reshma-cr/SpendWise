@model List<Category>

<div class="container">
    <div class="row mb-3 align-items-center">
        <div class="col">
            <h2 class="mb-0">List of Categories</h2>
        </div>
        <div class="col-auto">
            <a data-bs-toggle="modal"
               data-bs-target="#createCategoryModal" class="btn btn-dark"><i class="fa-solid fa-plus"></i> Add Category</a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="thead-light">
                <tr>
                    <th scope="col">Category</th>
                    <th scope="col" class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Count > 0)
                {
                    foreach (var category in Model)
                    {
                        <tr>
                            <td>@category.Name</td>
                            <td class="text-center">
                                <form asp-controller="Category" asp-action="DeleteCategory" asp-route-id="@category.Id" method="post" class="d-inline">
                                    <button type="submit"
                                            class="btn btn-link p-0 action-btn action-btn-danger"
                                            title="Delete">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted">No categories found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>


<div class="modal fade" id="createCategoryModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Create Category</h5>
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Category Name</label>
                        <input type="text"
                               name="Name"
                               class="form-control"
                               placeholder="Enter category name"
                               required />
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>

                    <button type="submit"
                            class="btn btn-primary">
                        Save
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>
