@model List<Expense>

<div class="container">
    <div class="row mb-3 align-items-center">
        <div class="col">
            <h2 class="mb-0">Expenses</h2>
        </div>
        <div class="col-auto">
            <a asp-controller="Expense" asp-action="Create" class="btn btn-dark"><i class="fa-solid fa-plus"></i> Add Expense</a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="thead-light">
                <tr>
                    <th scope="col">Date</th>
                    <th scope="col">Category</th>
                    <th scope="col">Description</th>
                    <th scope="col">Type</th>
                    <th scope="col" class="text-center">Amount</th>
                    <th scope="col" class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Count > 0)
                {
                    foreach (var expense in Model)
                    {
                        <tr>
                            <td>@expense.Date.ToString("yyyy-MM-dd")</td>
                            <td>@expense.Category?.Name</td>
                            <td>@(String.IsNullOrWhiteSpace(expense.Description) ? "—" : expense.Description)</td>
                            <td>
                                @if (expense.TransactionType == TransactionType.Expense)
                                {
                                    <span class="badge-expense">
                                        <i class="fa-solid fa-arrow-trend-down"></i> Expense
                                    </span>
                                }
                                else
                                {
                                    <span class="badge-credit">
                                        <i class="fa-solid fa-arrow-trend-up"></i> Credit
                                    </span>
                                }
                            </td>

                            <td class="text-center font-monospace fw-semibold">@String.Format(System.Globalization.CultureInfo.CurrentCulture, "{0:C}", expense.Amount)</td>
                            <td class="text-center">
                                <a asp-controller="Expense" asp-action="Edit" asp-route-id="@expense.Id" class="action-btn" title="Edit"><i class="fa-solid fa-pen"></i></a>

                                <form asp-controller="Expense" asp-action="DeleteExpense" asp-route-id="@expense.Id" method="post" class="d-inline">
                                    <button type="submit"
                                            class="btn btn-link p-0 action-btn action-btn-danger ms-1"
                                            title="Delete">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted">No expenses found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>