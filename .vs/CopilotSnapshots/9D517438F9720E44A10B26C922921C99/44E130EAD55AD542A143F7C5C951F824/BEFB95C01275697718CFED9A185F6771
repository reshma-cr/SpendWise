html {
  font-size: 14px;
}

@media (min-width: 768px) {
  html {
    font-size: 16px;
  }
}

:root {
  --bg: #FDF5EC; /* very light cream */
  --highlight: #F5D649; /* yellow highlight */
  --primary: #419577; /* teal */
  --accent: #F5AB41; /* warm orange accent */
  --muted: #6b6b6b; /* neutral muted */
}

body {
  margin-bottom: 60px;
  background-color: var(--bg);
  color: #1f2937;
  font-family: Inter, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
}

.btn:focus, .btn:active:focus, .btn-link.nav-link:focus, .form-control:focus, .form-check-input:focus {
  box-shadow: 0 0 0 0.08rem white, 0 0 0 0.22rem rgba(65,149,119,0.18);
}

/* Brand logo */
.brand-logo {
  font-family: 'Pacifico', cursive;
  font-size: 1.4rem;
  color: #F5AB41 !important; /* ensure logo color */
  /* background removed per request */
  padding: 0; /* remove extra padding now that there's no background */
  border-radius: 0;
}

/* Navigation tweaks */
.navbar {
  background-color: #FDF5EC;
}

.navbar .nav-link {
  color: var(--muted);
  margin: 0 0.75rem;
  font-weight: 700;
}

.navbar .nav-link:hover {
  color: var(--primary);
}

.btn-primary {
  color: #000;
  background-color: var(--primary);
  border-color: rgba(0,0,0,0.04);
  padding: 0.5rem 0.9rem;
  font-weight: 600;
  border-radius: 8px;
}

.btn-primary:hover {
  filter: brightness(0.95);
}

.btn-outline-primary {
  color: var(--primary);
  border-color: rgba(65,149,119,0.28);
  background-color: transparent;
  padding: 0.45rem 0.85rem;
  border-radius: 8px;
}

.btn-outline-primary:hover {
  background-color: rgba(65,149,119,0.06);
}

/* Sign-in / register colors */
.btn-signin {
  background-color: #F5AB41;
  color: #000 !important;
  border: none;
  font-weight: 700;
}

.btn-register {
  background-color: #F5D649;
  color: #000 !important;
  border: none;
  font-weight: 700;
}

/* Smaller auth buttons */
.auth-btn {
  padding: 0.28rem 0.55rem;
  font-size: 0.92rem;
  border-radius: 6px;
}

/* Hero section */
.hero {
  padding: 4rem 0;
  text-align: center;
}

.hero .lead-heading {
  font-size: 4.4rem;
  font-weight: 800;
  margin-bottom: 0.75rem;
  color: #419577;
  font-family: 'Roboto Condensed', Arial, Helvetica, sans-serif;
  letter-spacing: -0.5px;
}

@media (min-width: 768px) {
  .hero .lead-heading {
    font-size: 3rem;
    letter-spacing: -0.8px;
  }
}

.hero .subtext {
  font-size: 1rem;
  color: var(--muted);
  margin-bottom: 1.5rem;
}

/* Reduced CTA size, use accent color to stand out */
.hero .cta-btn {
  margin-bottom: 1.75rem;
  padding: 0.45rem 0.85rem;
  font-size: 1rem;
  border-radius: 8px;
  background-color: var(--accent);
  border-color: rgba(0,0,0,0.04);
  color: #000;
  font-weight: 700;
}

.hero .cta-btn:hover {
  filter: brightness(0.96);
}

.hero .hero-image {
  max-width: 900px;
  width: 100%;
  height: auto;
  border-radius: 10px;
  box-shadow: 0 10px 30px rgba(65,149,119,0.08);
  margin: 0 auto;
}

.footer {
  position: absolute;
  bottom: 0;
  width: 100%;
  white-space: nowrap;
  line-height: 60px;
  background: transparent;
}