html {
  font-size: 14px;
}

@media (min-width: 768px) {
  html {
    font-size: 16px;
  }
}

:root {
  --bg: #FAF7F2; /* page background */
  --card: #FFFFFF; /* card background */
  --section-highlight: #F1F8F4; /* section highlights */
  --cta: #2F7D5A; /* CTA button */
  --muted: #6b6b6b;
}

body {
  margin-bottom: 60px;
  background-color: var(--bg);
  color: #1f2937;
  font-family: Inter, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
}

/* account for fixed navbar */
body {
  padding-top: 70px; /* space for fixed navbar height */
  padding-bottom: 70px; /* space for fixed footer */
}

.btn:focus, .btn:active:focus, .btn-link.nav-link:focus, .form-control:focus, .form-check-input:focus {
  box-shadow: 0 0 0 0.08rem white, 0 0 0 0.22rem rgba(47,125,90,0.12);
}

/* Brand logo */
.brand-logo {
  font-family: 'Pacifico', cursive;
  font-size: 1.4rem;
  color: #F5AB41 !important; /* keep logo color as previously set */
  padding: 0;
  border-radius: 0;
}

/* Navigation tweaks */
.navbar {
  background-color: var(--bg);
}

.navbar .nav-link {
  color: var(--muted);
  margin: 0 0.75rem;
  font-weight: 700;
}

.navbar .nav-link:hover {
  color: #419577; /* retain a pleasant hover tone */
}

.btn-primary {
  color: #000;
  background-color: #419577; /* keep primary button color for other uses */
  border-color: rgba(0,0,0,0.04);
  padding: 0.5rem 0.9rem;
  font-weight: 600;
  border-radius: 8px;
}

.btn-primary:hover {
  filter: brightness(0.95);
}

.btn-outline-primary {
  color: #419577;
  border-color: rgba(65,149,119,0.28);
  background-color: transparent;
  padding: 0.45rem 0.85rem;
  border-radius: 8px;
}

.btn-outline-primary:hover {
  background-color: rgba(65,149,119,0.06);
}

/* Sign-in / register colors */
.btn-signin {
  background-color: #F5AB41;
  color: #000 !important; /* keep black text as requested earlier */
  border: none;
  font-weight: 700;
}

.btn-register {
  background-color: #F5D649;
  color: #000 !important;
  border: none;
  font-weight: 700;
}

/* Smaller auth buttons */
.auth-btn {
  padding: 0.28rem 0.55rem;
  font-size: 0.92rem;
  border-radius: 6px;
}

/* Hero section */
.hero {
  padding: 4rem 0;
  text-align: center;
}

.hero .lead-heading {
  font-size: 4.4rem;
  font-weight: 800;
  margin-bottom: 0.75rem;
  color: #A8D5BA; /* heading color retained */
  font-family: 'Roboto Condensed', Arial, Helvetica, sans-serif;
  letter-spacing: -0.5px;
}

@media (min-width: 768px) {
  .hero .lead-heading {
    font-size: 3rem;
    letter-spacing: -0.8px;
  }
}

.hero .subtext {
  font-size: 1rem;
  color: var(--muted);
  margin-bottom: 1.5rem;
}

/* CTA button uses new CTA color */
.hero .cta-btn {
  margin-bottom: 1.75rem;
  padding: 0.45rem 0.85rem;
  font-size: 1rem;
  border-radius: 8px;
  background-color: var(--cta);
  border-color: rgba(0,0,0,0.04);
  color: #000; /* keep black text as previously requested */
  font-weight: 700;
}

.hero .cta-btn:hover {
  filter: brightness(0.96);
}

/* Local home-image styling to fit nicely */
.hero .hero-image {
  max-width: 1200px;
  width: 75%;
  height: 420px;
  object-fit: cover;
  border-radius: 6px;
  box-shadow: 0 10px 30px rgba(122,126,158,0.08);
  margin: 0 auto;
}

.footer {
  position: fixed;
  bottom: 0;
  width: 100%;
  white-space: nowrap;
  line-height: 60px;
  background: transparent;
}

/* Features section */
.features-section {
  padding: 3.5rem 0 5rem;
  background: var(--section-highlight); /* very light mint background for the section */
}

.features-heading {
  font-size: 1.75rem;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 0.5rem;
}

.features-intro {
  color: var(--muted);
  max-width: 720px;
  margin: 0 auto 1.75rem;
}

.features-row {
  display: flex;
  gap: 1.25rem;
  flex-wrap: wrap;
}

.feature-card {
  background: var(--card); /* white cards */
  border-radius: 12px;
  padding: 1.25rem;
  box-shadow: 0 8px 24px rgba(15,23,42,0.06);
  text-align: left;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

.feature-icon {
  width: 56px;
  height: 56px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 10px;
  margin-bottom: 0.9rem;
}

.pastel-green {
  background: linear-gradient(135deg, rgba(168,213,186,0.36), rgba(168,213,186,0.12));
  color: #2f7b56;
}

.warm-orange {
  background: linear-gradient(135deg, rgba(245,171,65,0.32), rgba(245,171,65,0.10));
  color: #d9823d;
}

.blue-accent {
  background: linear-gradient(135deg, rgba(122,126,158,0.22), rgba(122,126,158,0.06));
  color: #3f44a2;
}

/* Force SVG icons to use the text color and make them pop */
.feature-icon svg,
.feature-icon svg * {
  width: 28px;
  height: 28px;
  fill: currentColor !important;
}

/* subtle icon shadow to increase perceived brightness */
.feature-icon {
  box-shadow: 0 4px 14px rgba(0,0,0,0.06);
}

.feature-title {
  font-size: 1.125rem;
  font-weight: 700;
  margin-bottom: 0.35rem;
}

.feature-subtext {
  color: var(--muted);
  font-size: 0.95rem;
}

@media (min-width: 992px) {
  .feature-card {
    min-height: 160px;
  }
}