@{
    ViewData["Title"] = "Home Page";
}

<div class="hero">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8 mx-auto text-center">
                <h1 class="lead-heading">Make smarter spending choices with SpendWise</h1>
                <p class="subtext">Quickly log expenses, visualize where your money goes, and build budgets that stick. Minimal, clear, and designed to help you reach your financial goals.</p>
                <a class="btn btn-primary cta-btn" asp-area="" asp-controller="Expense" asp-action="Create">Start Tracking</a>
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-12 text-center">
                <img class="hero-image" src="https://images.unsplash.com/photo-1541099649105-f69ad21f3246?q=80&w=1400&auto=format&fit=crop&ixlib=rb-4.0.3&s=3c4f4d3c7f2e9b4b5a1c6c3f22e8f0a2" alt="Money and budgeting illustration" />
            </div>
        </div>
    </div>
</div>

