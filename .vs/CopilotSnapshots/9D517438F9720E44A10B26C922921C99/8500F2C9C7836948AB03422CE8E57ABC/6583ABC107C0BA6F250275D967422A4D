html {
  font-size: 14px;
}

@media (min-width: 768px) {
  html {
    font-size: 16px;
  }
}

:root {
  --primary: #3a7bd5; /* pleasant blue */
  --muted: #6b7280;
  --accent: #6dd3b0; /* soft green accent */
  --bg: #f7fafc; /* very light background */
}

body {
  margin-bottom: 60px;
  background-color: var(--bg);
  color: #1f2937;
  font-family: Inter, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
}

.btn:focus, .btn:active:focus, .btn-link.nav-link:focus, .form-control:focus, .form-check-input:focus {
  box-shadow: 0 0 0 0.08rem white, 0 0 0 0.22rem rgba(58,123,213,0.18);
}

/* Brand logo */
.brand-logo {
  font-family: 'Pacifico', cursive;
  font-size: 1.4rem;
  color: var(--primary);
}

/* Navigation tweaks */
.navbar {
  background-color: #ffffff;
}

.navbar .nav-link {
  color: var(--muted);
  margin-right: 0.5rem;
}

.navbar .nav-link:hover {
  color: var(--primary);
}

.btn-primary {
  color: #fff;
  background-color: var(--primary);
  border-color: rgba(0,0,0,0.04);
  padding: 0.5rem 0.9rem;
  font-weight: 600;
  border-radius: 8px;
}

.btn-outline-primary {
  color: var(--primary);
  border-color: rgba(58,123,213,0.24);
  background-color: transparent;
  padding: 0.45rem 0.85rem;
  border-radius: 8px;
}

/* Hero section */
.hero {
  padding: 4rem 0;
  text-align: center;
}

.hero .lead-heading {
  font-size: 2rem;
  font-weight: 700;
  margin-bottom: 0.75rem;
  color: #0f172a;
}

.hero .subtext {
  font-size: 1rem;
  color: var(--muted);
  margin-bottom: 1.5rem;
}

/* Reduced CTA size */
.hero .cta-btn {
  margin-bottom: 1.75rem;
  padding: 0.5rem 0.9rem;
  font-size: 1rem;
  border-radius: 8px;
}

.hero .hero-image {
  max-width: 900px;
  width: 100%;
  height: auto;
  border-radius: 10px;
  box-shadow: 0 10px 30px rgba(15,23,42,0.08);
  margin: 0 auto;
}

.footer {
  position: absolute;
  bottom: 0;
  width: 100%;
  white-space: nowrap;
  line-height: 60px;
  background: transparent;
}