@model List<Expense>

<div class="container">
    <div class="row mb-3 align-items-center">
        <div class="col">
            <h2 class="mb-0">Expenses</h2>
        </div>
        <div class="col-auto">
            <a asp-controller="Expense" asp-action="Create" class="btn btn-dark">Add Expense</a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="thead-light">
                <tr>
                    <th scope="col">Date</th>
                    <th scope="col">Category</th>
                    <th scope="col">Description</th>
                    <th scope="col">Type</th>
                    <th scope="col" class="text-end">Amount</th>
                    <th scope="col" class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Count > 0)
                {
                    foreach (var expense in Model)
                    {
                        <tr>
                            <td>@expense.Date.ToString("yyyy-MM-dd")</td>
                            <td>@expense.Category?.Name</td>
                            <td>@(String.IsNullOrWhiteSpace(expense.Description) ? "—" : expense.Description)</td>
                            <td>@expense.TransactionType.ToString()</td>
                            <td class="text-end">@String.Format(System.Globalization.CultureInfo.CurrentCulture, "{0:C}", expense.Amount)</td>
                            <td class="text-center">
                                <a asp-controller="Expense" asp-action="Edit" asp-route-id="@expense.Id" class="btn btn-sm btn-outline-secondary me-1" aria-label="Edit">
                                    <!-- Pencil / edit icon -->
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                                        <path d="M12.146.854a.5.5 0 0 1 .708 0l2.292 2.292a.5.5 0 0 1 0 .708l-9.193 9.193a.5.5 0 0 1-.233.13l-4 1a.5.5 0 0 1-.61-.61l1-4a.5.5 0 0 1 .13-.232l9.193-9.193zM11.207 2L3 10.207V12h1.793L13 3.793 11.207 2z"/>
                                    </svg>
                                    <span class="visually-hidden">Edit</span>
                                </a>
                                <a asp-controller="Expense" asp-action="Delete" asp-route-id="@expense.Id" class="btn btn-sm btn-outline-danger" aria-label="Delete">
                                    <!-- Trash / delete icon -->
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                                        <path d="M5.5 5.5A.5.5 0 0 1 6 5h4a.5.5 0 0 1 .5.5V6h-5v-.5zM6.5 7h3v6a1 1 0 0 1-1 1h-1a1 1 0 0 1-1-1V7z"/>
                                        <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 1 1 0-2H5h6h3.5a1 1 0 0 1 1 1zM4.118 4L4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118zM2.5 2a.5.5 0 0 0-.5.5V3h12v-.5a.5.5 0 0 0-.5-.5H10.5l-.5-.5h-5l-.5.5H2.5z"/>
                                    </svg>
                                    <span class="visually-hidden">Delete</span>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted">No expenses found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>