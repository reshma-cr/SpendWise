@model List<Expense>

<div class="container">
    <div class="row mb-3 align-items-center">
        <div class="col">
            <h2 class="mb-0">Expenses</h2>
        </div>
        <div class="col-auto">
            <a asp-controller="Expense" asp-action="Create" class="btn btn-dark">Add Expense</a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="thead-light">
                <tr>
                    <th scope="col">Date</th>
                    <th scope="col">Category</th>
                    <th scope="col">Description</th>
                    <th scope="col">Type</th>
                    <th scope="col" class="text-end">Amount</th>
                    <th scope="col" class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Count > 0)
                {
                    foreach (var expense in Model)
                    {
                        <tr>
                            <td>@expense.Date.ToString("yyyy-MM-dd")</td>
                            <td>@expense.Category?.Name</td>
                            <td>@(String.IsNullOrWhiteSpace(expense.Description) ? "—" : expense.Description)</td>
                            <td>@expense.TransactionType.ToString()</td>
                            <td class="text-end">@String.Format(System.Globalization.CultureInfo.CurrentCulture, "{0:C}", expense.Amount)</td>
                            <td class="text-center">
                                <a asp-controller="Expense" asp-action="Edit" asp-route-id="@expense.Id" class="btn btn-sm btn-outline-secondary me-1">Edit</a>
                                <a asp-controller="Expense" asp-action="Delete" asp-route-id="@expense.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted">No expenses found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>