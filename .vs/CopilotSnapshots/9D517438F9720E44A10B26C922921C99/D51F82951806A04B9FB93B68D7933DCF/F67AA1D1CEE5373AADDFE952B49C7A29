html {
  font-size: 14px;
}

@media (min-width: 768px) {
  html {
    font-size: 16px;
  }
}

:root {
  --bg: #FFFFFF; /* page background: white */
  --card: #FFFFFF; /* card background */
  --section-highlight: #F5F5F5; /* subtle light grey section background */
  --cta: #111111; /* CTA: near-black */
  --muted: #6b6b6b; /* muted text */
  --logo: #111111; /* logo color */
  --icon-dark: #374151; /* icon/foreground dark grey */
}

body {
  margin-bottom: 60px;
  background-color: var(--bg);
  color: #111111;
  font-family: Inter, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
}

/* account for fixed navbar */
body {
  padding-top: 70px; /* space for fixed navbar height */
  padding-bottom: 140px; /* increased space for fixed footer so content isn't hidden */
}

/* Footer fixed bottom styling */
body {
  padding-bottom: 70px; /* make room for fixed footer */
}

.btn:focus, .btn:active:focus, .btn-link.nav-link:focus, .form-control:focus, .form-check-input:focus {
  box-shadow: 0 0 0 0.08rem white, 0 0 0 0.22rem rgba(0,0,0,0.08);
}

/* Brand logo */
.brand-logo {
  font-family: 'Pacifico', cursive;
  font-size: 1.4rem;
  color: var(--logo) !important; /* logo in black */
  padding: 0;
  border-radius: 0;
}

/* Navigation tweaks */
.navbar {
  background-color: var(--bg);
}

.navbar .nav-link {
  color: var(--muted);
  margin: 0 0.75rem;
  font-weight: 700;
}

.navbar .nav-link:hover {
  color: #111111;
}

.btn-primary {
  color: #fff;
  background-color: var(--cta);
  border-color: rgba(0,0,0,0.08);
  padding: 0.5rem 0.9rem;
  font-weight: 600;
  border-radius: 8px;
}

.btn-primary:hover {
  filter: brightness(0.9);
}

.btn-outline-primary {
  color: #111111;
  border-color: rgba(0,0,0,0.08);
  background-color: transparent;
  padding: 0.45rem 0.85rem;
  border-radius: 8px;
}

.btn-outline-primary:hover {
  background-color: rgba(0,0,0,0.04);
}

/* Sign-in / register colors: grayscale */
.btn-signin {
    background-color: #dee2e6; /* gray-400 */
    color: #111 !important;
    border: none;
    font-weight: 700;
}

.btn-register {
  background-color: #374151; /* gray-700 */
  color: #fff !important;
  border: none;
  font-weight: 700;
}

/* Smaller auth buttons */
.auth-btn {
  padding: 0.28rem 0.55rem;
  font-size: 0.92rem;
  border-radius: 6px;
}

/* Hero section */
.hero {
  padding: 4rem 0;
  text-align: center;
}

.hero .lead-heading {
  font-size: 4.4rem;
  font-weight: 800;
  margin-bottom: 0.75rem;
  color: var(--logo); /* heading in black */
  font-family: 'Roboto Condensed', Arial, Helvetica, sans-serif;
  letter-spacing: -0.5px;
}

@media (min-width: 768px) {
  .hero .lead-heading {
    font-size: 3rem;
    letter-spacing: -0.8px;
  }
}

.hero .subtext {
  font-size: 1rem;
  color: var(--muted);
  margin-bottom: 1.5rem;
}

/* CTA button uses new CTA color */
.hero .cta-btn {
  margin-bottom: 1.75rem;
  padding: 0.45rem 0.85rem;
  font-size: 1rem;
  border-radius: 8px;
  background-color: var(--cta);
  border-color: rgba(0,0,0,0.04);
  color: #fff; /* white text on dark CTA */
  font-weight: 700;
}

.hero .cta-btn:hover {
  filter: brightness(0.92);
}

/* Local home-image styling to fit nicely */
.hero .hero-image {
  max-width: 1200px;
  width: 100%;
  height: auto; /* let image keep its aspect ratio */
  object-fit: cover;
  border-radius: 6px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.06);
  margin: 0 auto;
  display: block;
}

/* Footer styles - fixed at bottom */
.site-footer {
  position: fixed;
  left: 0;
  bottom: 0;
  width: 100%;
  z-index: 1030;
  flex-shrink: 0;
  background: #000000; /* solid black */
  color: #ffffff; /* white text */
  border-top: none;
  box-shadow: 0 -2px 8px rgba(0,0,0,0.12);
}

.site-footer .container {
  max-width: 1100px;
}

.site-footer .footer-top {
  padding: 1.25rem 0 0.5rem;
}

.footer-brand {
  display: inline-block;
  font-family: 'Pacifico', cursive;
  font-size: 1.25rem;
  color: #ffffff;
  text-decoration: none; /* remove underline */
}

.footer-nav a {
  color: #ffffff; /* footer links white */
  text-decoration: none;
  font-weight: 700;
}

.footer-divider {
  border: none;
  border-top: 1px solid rgba(255,255,255,0.06);
  margin: 1.25rem auto;
}

.footer-bottom {
  padding: 0.75rem 0 1rem;
}

.footer-links a {
  color: #ffffff; /* white links */
  text-decoration: none;
}

.copyright {
  color: rgba(255,255,255,0.8);
}

@media (max-width: 576px) {
  .footer-bottom {
    flex-direction: column;
    gap: 0.75rem;
    text-align: center;
  }
}

/* Features section */
.features-section {
  padding: 3.5rem 0 5rem;
  background: var(--section-highlight); /* subtle light grey section background */
}

.features-heading {
  font-size: 1.75rem;
  font-weight: 700;
  color: #111111;
  margin-bottom: 0.5rem;
}

.features-intro {
  color: var(--muted);
  max-width: 720px;
  margin: 0 auto 1.75rem;
}

.features-row {
  display: flex;
  gap: -0.25rem; /* corrected gap */
  flex-wrap: wrap;
}

.feature-card {
  background: var(--card); /* white cards */
  border-radius: 12px;
  padding: 1.25rem;
  box-shadow: 0 8px 24px rgba(0,0,0,0.06);
  text-align: left;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: flex-start;
}

.feature-icon {
  width: 56px;
  height: 56px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 10px;
  margin-bottom: 0.9rem;
  box-shadow: 0 4px 14px rgba(0,0,0,0.06);
  overflow: hidden; /* ensure large images don't overflow */
  flex: 0 0 auto;
}

/* Constrain icon images so they always fit inside the circle */
.card-icon-img {
  width: 36px; /* slightly larger than before for better visibility */
  height: 36px;
  object-fit: contain;
  display: block;
}

.feature-title {
  font-size: 1.125rem;
  font-weight: 700;
  margin-bottom: 0.35rem;
}

.feature-subtext {
  color: var(--muted);
  font-size: 0.95rem;
}

@media (min-width: 992px) {
  .feature-card {
    min-height: 160px;
  }
}