html {
  font-size: 14px;
}

@media (min-width: 768px) {
  html {
    font-size: 16px;
  }
}

:root {
  --bg: #FFFFFF; /* page background: white */
  --card: #FFFFFF; /* card background */
  --section-highlight: #F5F5F5; /* subtle light grey section background */
  --cta: #111111; /* CTA: near-black */
  --muted: #6b6b6b; /* muted text */
  --logo: #111111; /* logo color */
  --icon-dark: #374151; /* icon/foreground dark grey */
}

body {
  margin-bottom: 60px;
  background-color: var(--bg);
  color: #111111;
  font-family: Inter, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
}

/* account for fixed navbar */
body {
  padding-top: 70px; /* space for fixed navbar height */
  padding-bottom: 0; /* no extra space required when footer not fixed */
}

/* Footer styles - non-fixed at page end */
.site-footer {
  flex-shrink: 0;
  background: #000000; /* solid black */
  color: #ffffff; /* white text */
  width: 100%;
  position: relative; /* not fixed */
}

.site-footer .container {
  max-width: 1100px;
}

.site-footer .footer-top {
  padding: 1.25rem 0 0.5rem;
}

.footer-brand {
  display: inline-block;
  font-family: 'Pacifico', cursive;
  font-size: 1.25rem;
  color: #ffffff;
  text-decoration: none; /* remove underline */
}

.footer-nav a {
  color: #ffffff; /* footer links white */
  text-decoration: none;
  font-weight: 700;
}

.footer-divider {
  border: none;
  border-top: 1px solid rgba(255,255,255,0.06);
  margin: 1.25rem auto;
}

.footer-bottom {
  padding: 0.75rem 0 1rem;
}

.footer-links a {
  color: #ffffff; /* white links */
  text-decoration: none;
}

.copyright {
  color: rgba(255,255,255,0.8);
}

@media (max-width: 576px) {
  .footer-bottom {
    flex-direction: column;
    gap: 0.75rem;
    text-align: center;
  }
}

/* Features section */
.features-section {
  padding: 3.5rem 0 5rem;
  background: var(--section-highlight); /* subtle light grey section background */
}

.features-heading {
  font-size: 1.75rem;
  font-weight: 700;
  color: #111111;
  margin-bottom: 0.5rem;
}

.features-intro {
  color: var(--muted);
  max-width: 720px;
  margin: 0 auto 1.75rem;
}

.features-row {
  display: flex;
  gap: -0.25rem; /* corrected gap */
  flex-wrap: wrap;
}

.feature-card {
  background: var(--card); /* white cards */
  border-radius: 12px;
  padding: 1.25rem;
  box-shadow: 0 8px 24px rgba(0,0,0,0.06);
  text-align: left;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: flex-start;
}

.feature-icon {
  width: 56px;
  height: 56px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 10px;
  margin-bottom: 0.9rem;
  box-shadow: 0 4px 14px rgba(0,0,0,0.06);
  overflow: hidden; /* ensure large images don't overflow */
  flex: 0 0 auto;
}

/* Constrain icon images so they always fit inside the circle */
.card-icon-img {
  width: 36px; /* slightly larger than before for better visibility */
  height: 36px;
  object-fit: contain;
  display: block;
}

.feature-title {
  font-size: 1.125rem;
  font-weight: 700;
  margin-bottom: 0.35rem;
}

.feature-subtext {
  color: var(--muted);
  font-size: 0.95rem;
}

@media (min-width: 992px) {
  .feature-card {
    min-height: 160px;
  }
}