html {
  font-size: 14px;
}

@media (min-width: 768px) {
  html { font-size: 16px; }
}

:root {
  --bg: #FFFFFF;
  --card: #FFFFFF;
  --section-highlight: #F5F5F5;
  --cta: #111111;
  --muted: #6b6b6b;
  --logo: #111111;
  --icon-dark: #374151;
}

/* Reset and base */
body {
  margin: 0;
  background-color: var(--bg);
  color: #111111;
  font-family: Inter, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
  /* space for fixed navbar */
  padding-top: 70px;
}

/* Page wrapper (use flex so footer sits at bottom when content is short) */
.page-wrapper {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

.page-content {
  flex: 1 0 auto;
}

/* Footer (non-fixed) */
#footer {
  background: #e9ecef;
  color: #212529;
  text-align: center;
  padding: 0.75rem 0;
  box-shadow: 0 -2px 6px rgba(0,0,0,0.04);
}

/* Buttons and focus */
.btn:focus, .btn:active:focus, .btn-link.nav-link:focus, .form-control:focus, .form-check-input:focus {
  box-shadow: 0 0 0 0.08rem white, 0 0 0 0.22rem rgba(0,0,0,0.08);
}

/* Brand logo */
.brand-logo {
  font-family: 'Pacifico', cursive;
  font-size: 1.4rem;
  color: var(--logo) !important;
  padding: 0;
}

/* Navigation tweaks */
.navbar { background-color: var(--bg); }
.navbar .nav-link {
  color: var(--muted);
  margin: 0 0.75rem;
  font-weight: 700;
}
.navbar .nav-link:hover { color: #111111; }

.btn-primary {
  color: #fff;
  background-color: var(--cta);
  border-color: rgba(0,0,0,0.08);
  padding: 0.5rem 0.9rem;
  font-weight: 600;
  border-radius: 8px;
}
.btn-primary:hover { filter: brightness(0.9); }

.btn-outline-primary {
  color: #111111;
  border-color: rgba(0,0,0,0.08);
  background-color: transparent;
  padding: 0.45rem 0.85rem;
  border-radius: 8px;
}
.btn-outline-primary:hover { background-color: rgba(0,0,0,0.04); }

/* Auth buttons */
.btn-signin {
  background-color: #dee2e6;
  color: #111 !important;
  border: none;
  font-weight: 700;
}
.btn-register {
  background-color: #374151;
  color: #fff !important;
  border: none;
  font-weight: 700;
}
.auth-btn { padding: 0.28rem 0.55rem; font-size: 0.92rem; border-radius: 6px; }

/* Hero section */
.hero { padding: 4rem 0; text-align: center; }
.hero .lead-heading {
  font-size: 4.4rem; font-weight: 800; margin-bottom: 0.75rem; color: var(--logo);
  font-family: 'Roboto Condensed', Arial, Helvetica, sans-serif; letter-spacing: -0.5px;
}
@media (min-width: 768px) { .hero .lead-heading { font-size: 3rem; letter-spacing: -0.8px; } }
.hero .subtext { font-size: 1rem; color: var(--muted); margin-bottom: 1.5rem; }
.hero .cta-btn { margin-bottom: 1.75rem; padding: 0.45rem 0.85rem; font-size: 1rem; border-radius: 8px; background-color: var(--cta); border-color: rgba(0,0,0,0.04); color: #fff; font-weight: 700; }
.hero .cta-btn:hover { filter: brightness(0.92); }
.hero .hero-image { max-width: 1200px; width: 100%; height: auto; object-fit: cover; border-radius: 6px; box-shadow: 0 10px 30px rgba(0,0,0,0.06); margin: 0 auto; display: block; }

/* Features section */
.features-section { padding: 3.5rem 0 5rem; margin:20px; background: var(--section-highlight); }
.features-heading { font-size: 1.75rem; font-weight: 700; color: #111111; margin-bottom: 0.5rem; }
.features-intro { color: var(--muted); max-width: 720px; margin: 0 auto 1.75rem; }

.features-row { display: flex; gap: -0.75rem; flex-wrap: wrap; justify-content: center; }

.feature-card { background: var(--card); border-radius: 12px; padding: 1.25rem; box-shadow: 0 8px 24px rgba(0,0,0,0.06); text-align: left; height: 100%; display: flex; flex-direction: column; justify-content: flex-start; align-items: flex-start; }

.feature-icon { width: 56px; height: 56px; display: inline-flex; align-items: center; justify-content: center; border-radius: 10px; margin-bottom: 0.9rem; box-shadow: 0 4px 14px rgba(0,0,0,0.06); overflow: hidden; flex: 0 0 auto; }
.card-icon-img { width: 36px; height: 36px; object-fit: contain; display: block; }
.feature-title { font-size: 1.125rem; font-weight: 700; margin-bottom: 0.35rem; }
.feature-subtext { color: var(--muted); font-size: 0.95rem; }
@media (min-width: 992px) { .feature-card { min-height: 160px; } }

/* Signup CTA section */
.signup-cta {
  background-color: #000;
  color: #fff;
  margin-bottom: 3.5rem; /* add extra space below section so footer isn't tight */
}

.signup-cta-heading {
  font-size: 2rem;
  font-weight: 800;
  color: #fff;
}

.btn-signup {
  background-color: #fff !important; /* ensure white */
  color: #000 !important; /* ensure black text */
  border: none;
  padding: 0.6rem 1.25rem;
  border-radius: 8px;
  font-weight: 700;
}

.btn-signup:hover {
  background-color: #f2f2f2;
}