html {
  font-size: 14px;
}

@media (min-width: 768px) {
  html {
    font-size: 16px;
  }
}

.btn:focus, .btn:active:focus, .btn-link.nav-link:focus, .form-control:focus, .form-check-input:focus {
  box-shadow: 0 0 0 0.1rem white, 0 0 0 0.25rem #258cfb;
}

html {
  position: relative;
  min-height: 100%;
}

body {
  margin-bottom: 60px;
}

/* Brand logo */
.brand-logo {
  font-family: 'Pacifico', cursive;
  font-size: 1.5rem;
  color: #1b6ec2;
}

/* Hero section */
.hero {
  padding: 4rem 0;
  text-align: center;
}

.hero .lead-heading {
  font-size: 2.25rem;
  font-weight: 700;
  margin-bottom: 1rem;
}

.hero .subtext {
  font-size: 1.125rem;
  color: #555;
  margin-bottom: 2rem;
}

.hero .cta-btn {
  margin-bottom: 2rem;
}

.hero .hero-image {
  max-width: 100%;
  height: auto;
  border-radius: 8px;
  box-shadow: 0 8px 24px rgba(0,0,0,0.12);
}